{
    "name": "ecommerce/marketplace",
    "description": "Modern, professional eCommerce marketplace built with OOP and MVC",
    "version": "2.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "ECommerce\\": "core/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "lint": "phpstan analyse app core"
    },
    "keywords": [
        "ecommerce",
        "marketplace",
        "php",
        "mvc",
        "oop",
        "shopping",
        "orders",
        "ratings"
    ]
}

